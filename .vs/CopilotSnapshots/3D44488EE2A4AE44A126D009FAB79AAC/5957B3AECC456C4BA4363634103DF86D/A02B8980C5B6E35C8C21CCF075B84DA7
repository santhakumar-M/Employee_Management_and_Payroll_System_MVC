using EmployeeHrSystem.Models;
using Microsoft.EntityFrameworkCore;

namespace EmployeeHrSystem.Services
{
    public class PayrollService : IPayrollService
    {
        private readonly ApplicationContext _context;

        public PayrollService(ApplicationContext context)
        {
            _context = context;
        }

        public async Task<List<Payroll>> GetAllPayrollsAsync()
        {
            return await _context.Payrolls
                .Include(p => p.Employee)
                .OrderByDescending(p => p.PayrollId)
                .ToListAsync();
        }

        public async Task<Payroll?> GetPayrollByIdAsync(int id)
        {
            return await _context.Payrolls
                .Include(p => p.Employee)
                .FirstOrDefaultAsync(p => p.PayrollId == id);
        }

        public async Task<List<Payroll>> GetEmployeePayrollsAsync(int employeeId)
        {
            return await _context.Payrolls
                .Include(p => p.Employee)
                .Where(p => p.EmployeeId == employeeId)
                .OrderByDescending(p => p.PayrollId)
                .ToListAsync();
        }

        public async Task<bool> ProcessPayrollAsync(Payroll payroll)
        {
            try
            {
                // Validate employee exists
                var employee = await _context.Employees.FindAsync(payroll.EmployeeId);
                if (employee == null) return false;

                // Auto-populate salary if not provided
                if (payroll.BasicSalary == 0)
                    payroll.BasicSalary = employee.BasicSalary ?? 0;

                // Calculate net salary
                payroll.NetSalary = payroll.BasicSalary - payroll.Deductions;

                _context.Payrolls.Add(payroll);
                await _context.SaveChangesAsync();
                return true;
            }
            catch
            {
                return false;
            }
        }

        public async Task<bool> UpdatePayrollAsync(Payroll payroll)
        {
            try
            {
                // Recalculate net salary
                payroll.NetSalary = payroll.BasicSalary - payroll.Deductions;

                _context.Entry(payroll).State = EntityState.Modified;
                await _context.SaveChangesAsync();
                return true;
            }
            catch
            {
                return false;
            }
        }

        public async Task<bool> DeletePayrollAsync(int id)
        {
            try
            {
                var payroll = await _context.Payrolls.FindAsync(id);
                if (payroll == null) return false;

                _context.Payrolls.Remove(payroll);
                await _context.SaveChangesAsync();
                return true;
            }
            catch
            {
                return false;
            }
        }

        public async Task<List<Payroll>> GetPayrollsByMonthAsync(string month)
        {
            return await _context.Payrolls
                .Include(p => p.Employee)
                .Where(p => p.Month == month)
                .OrderByDescending(p => p.PayrollId)
                .ToListAsync();
        }

        public async Task<bool> UpdatePaymentStatusAsync(int payrollId, string status)
        {
            try
            {
                var payroll = await _context.Payrolls.FindAsync(payrollId);
                if (payroll == null) return false;

                payroll.PaymentStatus = status;
                _context.Entry(payroll).State = EntityState.Modified;
                await _context.SaveChangesAsync();
                return true;
            }
            catch
            {
                return false;
            }
        }
    }
}

using EmployeeHrSystem.Models;
using Microsoft.EntityFrameworkCore;

namespace EmployeeHrSystem.Services
{
    public class PayrollService : IPayrollService
    {
        private readonly ApplicationContext _context;

        public PayrollService(ApplicationContext context)
        {
            _context = context;
        }

        public async Task<List<Payroll>> GetAllPayrollsAsync()
        {
            return await _context.Payrolls
                .Include(p => p.Employee)
                .OrderByDescending(p => p.PayrollId)
                .ToListAsync();
        }

        public async Task<Payroll?> GetPayrollByIdAsync(int id)
        {
            return await _context.Payrolls
                .Include(p => p.Employee)
                .FirstOrDefaultAsync(p => p.PayrollId == id);
        }

        public async Task<List<Payroll>> GetEmployeePayrollsAsync(int employeeId)
        {
            return await _context.Payrolls
                .Include(p => p.Employee)
                .Where(p => p.EmployeeId == employeeId)
                .OrderByDescending(p => p.PayrollId)
                .ToListAsync();
        }

        public async Task<bool> ProcessPayrollAsync(Payroll payroll, bool applyLeaveDeduction = false, decimal perDayDeduction = 0m)
        {
            try
            {
                // Validate employee exists
                var employee = await _context.Employees.FindAsync(payroll.EmployeeId);
                if (employee == null) return false;

                // Auto-populate salary if not provided
                if (payroll.BasicSalary == 0)
                    payroll.BasicSalary = employee.BasicSalary ?? 0;

                // Apply leave-based deduction if requested
                if (applyLeaveDeduction && perDayDeduction > 0)
                {
                    // Calculate unpaid leave days based on attendance records.
                    // Count distinct dates in the month where the employee was marked ABSENT.
                    var monthKey = payroll.Month; // expected YYYY-MM
                    int unpaidLeaveDays = 0;

                    var monthParts = monthKey.Split('-');
                    if (monthParts.Length == 2 && int.TryParse(monthParts[0], out var y) && int.TryParse(monthParts[1], out var m))
                    {
                        var att = await _context.Attendances
                            .Where(a => a.EmployeeId == payroll.EmployeeId && a.Date.Year == y && a.Date.Month == m)
                            .ToListAsync();

                        if (att.Any())
                        {
                            // Group by date and count days where any record is ABSENT
                            unpaidLeaveDays = att
                                .GroupBy(a => a.Date)
                                .Count(g => g.Any(x => x.Status != null && x.Status.ToUpper() == "ABSENT"));
                        }
                        else
                        {
                            // Fallback: try MonthlyAttendanceSummary if attendance rows are not present
                            var summary = await _context.MonthlyAttendanceSummaries
                                .FirstOrDefaultAsync(s => s.EmployeeId == payroll.EmployeeId && s.Month == monthKey);
                            if (summary != null)
                            {
                                unpaidLeaveDays = Math.Max(0, summary.TotalWorkingDays - summary.DaysPresent);
                            }
                        }
                    }

                    var leaveDeduction = unpaidLeaveDays * perDayDeduction;
                    payroll.Deductions += leaveDeduction;
                }

                // Calculate net salary
                payroll.NetSalary = payroll.BasicSalary - payroll.Deductions;

                // Prevent duplicate payroll entries for same employee & month
                var existing = await _context.Payrolls.FirstOrDefaultAsync(p => p.EmployeeId == payroll.EmployeeId && p.Month == payroll.Month);
                if (existing != null)
                {
                    // Update existing record
                    existing.BasicSalary = payroll.BasicSalary;
                    existing.Deductions = payroll.Deductions;
                    existing.NetSalary = payroll.NetSalary;
                    existing.PaymentStatus = payroll.PaymentStatus;
                    _context.Entry(existing).State = EntityState.Modified;
                }
                else
                {
                    _context.Payrolls.Add(payroll);
                }

                await _context.SaveChangesAsync();
                return true;
            }
            catch
            {
                return false;
            }
        }

        public async Task<bool> UpdatePayrollAsync(Payroll payroll)
        {
            try
            {
                // Recalculate net salary
                payroll.NetSalary = payroll.BasicSalary - payroll.Deductions;

                _context.Entry(payroll).State = EntityState.Modified;
                await _context.SaveChangesAsync();
                return true;
            }
            catch
            {
                return false;
            }
        }

        public async Task<bool> DeletePayrollAsync(int id)
        {
            try
            {
                var payroll = await _context.Payrolls.FindAsync(id);
                if (payroll == null) return false;

                _context.Payrolls.Remove(payroll);
                await _context.SaveChangesAsync();
                return true;
            }
            catch
            {
                return false;
            }
        }

        public async Task<List<Payroll>> GetPayrollsByMonthAsync(string month)
        {
            return await _context.Payrolls
                .Include(p => p.Employee)
                .Where(p => p.Month == month)
                .OrderByDescending(p => p.PayrollId)
                .ToListAsync();
        }

        public async Task<bool> UpdatePaymentStatusAsync(int payrollId, string status)
        {
            try
            {
                var payroll = await _context.Payrolls.FindAsync(payrollId);
                if (payroll == null) return false;

                payroll.PaymentStatus = status;
                _context.Entry(payroll).State = EntityState.Modified;
                await _context.SaveChangesAsync();
                return true;
            }
            catch
            {
                return false;
            }
        }
    }
}

@model EmployeeHrSystem.Models.HRReportViewModel

<div class="card card-custom mb-4">
    <div class="card-body d-flex align-items-center justify-content-between report-header">
        <div>
            <h3 class="mb-0">@Model.CompanyName</h3>
            <div class="muted">@Model.ReportTitle — <small>@Model.ReportingPeriod</small></div>
        </div>
        <div class="text-end">
            @if (!string.IsNullOrEmpty(Model.CompanyLogoUrl))
            {
                <img src="@Model.CompanyLogoUrl" alt="logo" style="max-height:64px;" />
            }
            <div class="muted">Generated: @Model.GeneratedOn.ToString("yyyy-MM-dd")</div>
        </div>
    </div>
</div>

<!-- Key metrics -->
<div class="row mb-3 gx-3">
    <div class="col-md-3">
        <div class="card p-3 card-custom report-metric">
            <div class="d-flex align-items-center">
                <div class="me-3 bg-light rounded-circle p-2"><i class="bi bi-people-fill text-accent fs-4"></i></div>
                <div>
                    <div class="muted">Total employees</div>
                    <div class="h5 mb-0">@Model.TotalEmployees</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3 card-custom report-metric">
            <div class="d-flex align-items-center">
                <div class="me-3 bg-light rounded-circle p-2"><i class="bi bi-person-check text-success fs-4"></i></div>
                <div>
                    <div class="muted">Active employees</div>
                    <div class="h5 mb-0">@Model.ActiveEmployees</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3 card-custom report-metric">
            <div class="d-flex align-items-center">
                <div class="me-3 bg-light rounded-circle p-2"><i class="bi bi-currency-dollar text-warning fs-4"></i></div>
                <div>
                    <div class="muted">Total gross</div>
                    <div class="h5 mb-0">@Model.TotalGrossSalary:C</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card p-3 card-custom report-metric">
            <div class="d-flex align-items-center">
                <div class="me-3 bg-light rounded-circle p-2"><i class="bi bi-wallet2 text-primary fs-4"></i></div>
                <div>
                    <div class="muted">Net disbursed</div>
                    <div class="h5 mb-0">@Model.TotalNetSalary:C</div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row gx-3">
    <div class="col-lg-7">
        <div class="card card-custom p-3">
            <h6 class="mb-3">Department payroll distribution</h6>
            <canvas id="deptChart" style="height:260px;"></canvas>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card card-custom p-3 mb-3">
            <h6 class="mb-3">Payroll overview</h6>
            <dl class="row">
                <dt class="col-6 muted">Total deductions</dt>
                <dd class="col-6 text-end">@Model.TotalDeductions:C</dd>

                <dt class="col-6 muted">Average salary</dt>
                <dd class="col-6 text-end">@Model.AverageSalary:C</dd>

                <dt class="col-6 muted">Paid leave days</dt>
                <dd class="col-6 text-end">@Model.PaidLeaveDays</dd>

                <dt class="col-6 muted">Loss of pay</dt>
                <dd class="col-6 text-end">@Model.LossOfPay:C</dd>
            </dl>
        </div>

        <div class="card card-custom p-3">
            <h6 class="mb-2">Deductions</h6>
            <ul class="list-unstyled mb-0">
                <li>Tax (TDS): <strong>@Model.TotalTax:C</strong></li>
                <li>Provident Fund: <strong>@Model.TotalPF:C</strong></li>
                <li>Insurance: <strong>@Model.TotalInsurance:C</strong></li>
                <li>Loan deductions: <strong>@Model.TotalLoanDeductions:C</strong></li>
            </ul>
        </div>
    </div>
</div>

<section class="mt-4">
    <h6>Salary breakdown</h6>
    <div class="row">
        <div class="col-md-3"><div class="border p-2">Basic Pay<br /><strong>@Model.TotalBasic:C</strong></div></div>
        <div class="col-md-3"><div class="border p-2">Allowances<br /><strong>@Model.TotalAllowances:C</strong></div></div>
        <div class="col-md-3"><div class="border p-2">Overtime<br /><strong>@Model.TotalOvertime:C</strong></div></div>
        <div class="col-md-3"><div class="border p-2">Other benefits<br /><strong>@Model.TotalOtherBenefits:C</strong></div></div>
    </div>
</section>

<section class="mt-4">
    <h6>Department table</h6>
    <table class="table table-sm table-striped">
        <thead>
            <tr><th>Department</th><th class="text-end">Employees</th><th class="text-end">Payroll Cost</th></tr>
        </thead>
        <tbody>
            @foreach (var d in Model.DepartmentBreakdown)
            {
                <tr>
                    <td>@d.DepartmentName</td>
                    <td class="text-end">@d.EmployeeCount</td>
                    <td class="text-end">@d.PayrollCost:C</td>
                </tr>
            }
        </tbody>
    </table>
</section>

<section class="mt-4">
    <h6>Authorization</h6>
    <div class="row">
        <div class="col-md-4 text-center"><div class="border-top pt-2">Prepared by<br /><strong>@Model.PreparedBy</strong></div></div>
        <div class="col-md-4 text-center"><div class="border-top pt-2">Reviewed by<br /><strong>@Model.ReviewedBy</strong></div></div>
        <div class="col-md-4 text-center"><div class="border-top pt-2">Approved by<br /><strong>@Model.ApprovedBy</strong></div></div>
    </div>
</section>

<div class="text-muted small mt-3">Generated by Employee Payroll Management System</div>

<!-- Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.3.0/dist/chart.umd.min.js"></script>
<script>
    (function(){
        var labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DepartmentBreakdown.Select(d => d.DepartmentName)));
        var data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DepartmentBreakdown.Select(d => d.PayrollCost)));

        var ctx = document.getElementById('deptChart');
        if (!ctx) return;

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Payroll cost',
                    data: data,
                    backgroundColor: 'rgba(79,70,229,0.85)'
                }]
            },
            options: {
                plugins: { legend: { display: false } },
                scales: { y: { ticks: { callback: function(v){ return new Intl.NumberFormat('en-US',{style:'currency',currency:'USD'}).format(v); } } } , x: { ticks: { autoSkip: false } } }
            }
        });
    })();
</script>

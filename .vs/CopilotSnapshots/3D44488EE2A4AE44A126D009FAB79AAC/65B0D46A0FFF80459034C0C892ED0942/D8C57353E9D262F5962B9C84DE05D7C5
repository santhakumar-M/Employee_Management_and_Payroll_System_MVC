@model EmployeeHrSystem.Models.HRReportViewModel

<div class="card mb-3">
    <div class="card-body">
        <div class="d-flex align-items-center justify-content-between">
            <div>
                <h4 class="mb-0">@Model.CompanyName</h4>
                <small class="text-muted">@Model.ReportTitle</small>
            </div>
            <div class="text-end">
                <!-- Logo placeholder -->
                @if (!string.IsNullOrEmpty(Model.CompanyLogoUrl))
                {
                    <img src="@Model.CompanyLogoUrl" alt="logo" style="max-height:60px;" />
                }
                <div>
                    <strong>Reporting Period:</strong> @Model.ReportingPeriod
                </div>
                <div>
                    <strong>Generated:</strong> @Model.GeneratedOn.ToString("yyyy-MM-dd")
                </div>
            </div>
        </div>
    </div>
</div>

<section class="mb-4">
    <h5>Employee Summary</h5>
    <div class="row">
        <div class="col-md-3">
            <div class="border p-2">Total employees<br /><strong>@Model.TotalEmployees</strong></div>
        </div>
        <div class="col-md-3">
            <div class="border p-2">Active employees<br /><strong>@Model.ActiveEmployees</strong></div>
        </div>
        <div class="col-md-3">
            <div class="border p-2">New hires<br /><strong>@Model.NewHires</strong></div>
        </div>
        <div class="col-md-3">
            <div class="border p-2">Resignations<br /><strong>@Model.Resignations</strong></div>
        </div>
    </div>
</section>

<section class="mb-4">
    <h5>Payroll Overview</h5>
    <div class="row">
        <div class="col-md-3 border p-2">Total gross salary paid<br /><strong>@Model.TotalGrossSalary:C</strong></div>
        <div class="col-md-3 border p-2">Total deductions<br /><strong>@Model.TotalDeductions:C</strong></div>
        <div class="col-md-3 border p-2">Total net salary disbursed<br /><strong>@Model.TotalNetSalary:C</strong></div>
        <div class="col-md-3 border p-2">Average salary per employee<br /><strong>@Model.AverageSalary:C</strong></div>
    </div>
</section>

<section class="mb-4">
    <h5>Salary Breakdown</h5>
    <ul>
        <li>Basic Pay: <strong>@Model.TotalBasic:C</strong></li>
        <li>Allowances (HRA, TA, bonuses): <strong>@Model.TotalAllowances:C</strong></li>
        <li>Overtime pay: <strong>@Model.TotalOvertime:C</strong></li>
        <li>Other benefits: <strong>@Model.TotalOtherBenefits:C</strong></li>
    </ul>
</section>

<section class="mb-4">
    <h5>Deductions Summary</h5>
    <ul>
        <li>Tax (TDS): <strong>@Model.TotalTax:C</strong></li>
        <li>Provident Fund (PF): <strong>@Model.TotalPF:C</strong></li>
        <li>Insurance: <strong>@Model.TotalInsurance:C</strong></li>
        <li>Loan / advance deductions: <strong>@Model.TotalLoanDeductions:C</strong></li>
    </ul>
</section>

<section class="mb-4">
    <h5>Department‑Wise Payroll Distribution</h5>
    <table class="table table-sm table-striped">
        <thead>
            <tr>
                <th>Department</th>
                <th>Employee Count</th>
                <th>Payroll Cost</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Model.DepartmentBreakdown)
            {
                <tr>
                    <td>@d.DepartmentName</td>
                    <td>@d.EmployeeCount</td>
                    <td>@d.PayrollCost:C</td>
                </tr>
            }
        </tbody>
    </table>
</section>

<section class="mb-4">
    <h5>Attendance & Leave Impact</h5>
    <ul>
        <li>Paid leave days: <strong>@Model.PaidLeaveDays</strong></li>
        <li>Unpaid leave days: <strong>@Model.UnpaidLeaveDays</strong></li>
        <li>Loss of pay (LOP) summary: <strong>@Model.LossOfPay:C</strong></li>
    </ul>
</section>

<section class="mb-4">
    <h5>Compliance & Notes</h5>
    <p><strong>Statutory compliance status:</strong> @Model.ComplianceStatus</p>
    @if (!string.IsNullOrEmpty(Model.Notes))
    {
        <p><strong>Remarks:</strong> @Model.Notes</p>
    }
</section>

<section class="mb-4">
    <h5>Authorization</h5>
    <div class="row">
        <div class="col-md-4 text-center">
            <div class="border-top pt-2">Prepared by<br /><strong>@Model.PreparedBy</strong></div>
        </div>
        <div class="col-md-4 text-center">
            <div class="border-top pt-2">Reviewed by<br /><strong>@Model.ReviewedBy</strong></div>
        </div>
        <div class="col-md-4 text-center">
            <div class="border-top pt-2">Approved by<br /><strong>@Model.ApprovedBy</strong></div>
        </div>
    </div>
</section>

<div class="text-muted small">Generated by Employee Payroll Management System</div>

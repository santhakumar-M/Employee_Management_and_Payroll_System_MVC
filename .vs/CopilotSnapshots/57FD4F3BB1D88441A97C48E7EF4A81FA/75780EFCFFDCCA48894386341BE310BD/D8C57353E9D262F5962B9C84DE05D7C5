@model EmployeeHrSystem.Models.HRReportViewModel

<div class="card card-custom mb-4">
    <div class="card-body d-flex align-items-center justify-content-between report-header">
        <div>
            <h4 class="mb-0">@Model.CompanyName</h4>
            <div class="muted">@Model.ReportTitle — <small>@Model.ReportingPeriod</small></div>
        </div>
        <div class="text-end">
            <div class="muted">Generated: @Model.GeneratedOn.ToString("yyyy-MM-dd")</div>
            <div class="mt-2">
                <a class="btn btn-sm btn-outline-primary me-2" href="@Url.Action("ExportCsv", "Report", new { year = Model.ReportingYear, month = Model.ReportingMonth })">
                    <i class="bi bi-file-earmark-arrow-down"></i> Export CSV
                </a>
                <button class="btn btn-sm btn-primary" onclick="window.print()"><i class="bi bi-printer"></i> Print</button>
            </div>
        </div>
    </div>
</div>

<div class="row gx-3">
    <div class="col-md-6">
        <div class="card card-custom p-3 mb-3">
            <h6 class="mb-2">Employee summary</h6>
            <p class="mb-1 muted">Total employees: <strong>@Model.TotalEmployees</strong></p>
            <p class="mb-1 muted">Active employees: <strong>@Model.ActiveEmployees</strong></p>
            <p class="mb-1 muted">New hires: <strong>@Model.NewHires</strong></p>
            <p class="mb-0 muted">Resignations: <strong>@Model.Resignations</strong></p>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card card-custom p-3 mb-3">
            <h6 class="mb-2">Payroll overview</h6>
            <p class="mb-1 muted">Total gross salary paid: <strong>@Model.TotalGrossSalary:C</strong></p>
            <p class="mb-1 muted">Total deductions: <strong>@Model.TotalDeductions:C</strong></p>
            <p class="mb-1 muted">Total net salary disbursed: <strong>@Model.TotalNetSalary:C</strong></p>
            <p class="mb-0 muted">Average salary per employee: <strong>@Model.AverageSalary:C</strong></p>
        </div>
    </div>
</div>

<div class="text-muted small mt-3">Generated by Employee Payroll Management System</div>

@model EmployeeHrSystem.Models.EmployeeAttendanceSummaryViewModel

@{
    ViewData["Title"] = "My Profile";
    var monthDisplay = DateTime.ParseExact(Model.Month + "-01", "yyyy-MM-dd", null).ToString("MMMM yyyy");
}

<div class="card card-custom p-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h5 class="mb-0">@Model.Employee?.Name</h5>
            <small class="muted">Designation: @Model.Employee?.Designation</small>
            <br />
            <small class="muted">Period: @monthDisplay</small>
        </div>
        <div>
            <a asp-controller="Dashboard" asp-action="Employee" class="btn btn-sm btn-outline-secondary">Dashboard</a>
        </div>
    </div>

    <div class="row mb-3">
        <div class="col-md-4">
            <div class="border p-3 text-center">
                <div class="muted">Present days</div>
                <div class="h2">@Model.PresentDays</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="border p-3 text-center">
                <div class="muted">Absent days</div>
                <div class="h2">@Model.AbsentDays</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="border p-3 text-center">
                <div class="muted">Attendance %</div>
                <div class="h2">@((Model.Records.Count > 0) ? (Model.PresentDays * 100 / Model.Records.Count) : 0)%</div>
            </div>
        </div>
    </div>

    <h6>Detailed records</h6>
    <div class="table-responsive">
        <table class="table table-sm">
            <thead>
                <tr><th>Date</th><th>Day</th><th>Status</th></tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Records.OrderByDescending(x => x.Date))
                {
                    <tr>
                        <td>@r.Date.ToString("yyyy-MM-dd")</td>
                        <td>@r.Date.DayOfWeek</td>
                        <td>
                            @if (r.Status == "PRESENT")
                            {
                                <span class="badge bg-success">Present</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Absent</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

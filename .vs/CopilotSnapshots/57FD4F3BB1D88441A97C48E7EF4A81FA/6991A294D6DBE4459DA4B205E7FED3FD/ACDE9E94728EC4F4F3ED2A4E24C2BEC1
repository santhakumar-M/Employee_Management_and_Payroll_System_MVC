@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " — " : "")Employee HR System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body {
            background: linear-gradient(180deg,#f6f8ff 0%, #ffffff 50%);
            font-family: 'Segoe UI', system-ui, -apple-system, "Helvetica Neue", Arial;
            color: #1f2937;
            -webkit-font-smoothing:antialiased;
        }

        /* ── Navbar ── */
        .navbar {
            background: linear-gradient(90deg,#111827 0%, #3730a3 100%) !important;
            box-shadow: 0 6px 24px rgba(15,23,42,.12);
            border-bottom: 1px solid rgba(255,255,255,.03);
        }
        .navbar-brand { font-weight: 800; letter-spacing: .04em; font-size: 1.15rem; }
        .navbar-brand span { color: #c7d2fe; }
        .nav-link { font-weight: 600; font-size: .9rem; border-radius: 10px; padding: .45rem .85rem !important; transition: background .18s, transform .12s; }
        .nav-link:hover, .nav-link.active { background: rgba(255,255,255,.06); transform: translateY(-1px); }

        /* ── Role badge ── */
        .role-badge { font-size: .75rem; font-weight: 700; padding: .3rem .65rem; border-radius: 18px; letter-spacing: .04em; text-transform: uppercase; }

        /* ── Page wrapper ── */
        .page-content { padding: 2.25rem 1rem; max-width: 1200px; margin: 0 auto; }

        /* ── Card styles ── */
        .card-custom { border: 0; border-radius: 12px; box-shadow: 0 6px 18px rgba(31,41,55,.06); }
        .card-header-compact { background: transparent; border-bottom: none; padding-bottom: 0.5rem; }

        /* ── Tables ── */
        table.table { background: #fff; border-radius: 8px; overflow: hidden; }
        table.table thead th { background: rgba(15,23,42,.04); font-weight: 700; }

        /* ── Buttons ── */
        .btn-primary.custom { background: linear-gradient(90deg,#4f46e5,#06b6d4); border: 0; box-shadow: 0 6px 18px rgba(79,70,229,.12); }

        /* ── Dashboard cards ── */
        .dashboard-card { transition: transform .18s, box-shadow .18s; cursor: pointer; }
        .dashboard-card:hover { transform: translateY(-6px); box-shadow: 0 14px 36px rgba(15,23,42,.10) !important; }

        /* ── Small helpers ── */
        .muted { color: #6b7280; }
        .text-accent { color: #4f46e5; }

        /* ── Footer ── */
        .site-footer { padding: 1rem 0; margin-top: 2rem; color: #6b7280; font-size: .875rem; }
    </style>
</head>
<body>

@{
    var hideNav = TempData["HideNav"] as string == "true";
}

@if (!hideNav && User.Identity?.IsAuthenticated == true)
{
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "";

    string roleBadgeClass = role switch {
        "Admin"           => "bg-primary",
        "HR Officer"      => "bg-success",
        "Payroll Officer" => "bg-info text-dark",
        "Manager"         => "bg-warning text-dark",
        "Employee"        => "bg-secondary",
        _                 => "bg-dark"
    };

    string dashAction = role switch {
        "Admin"           => "Admin",
        "HR Officer"      => "HR",
        "Payroll Officer" => "Payroll",
        "Manager"         => "Manager",
        "Employee"        => "Employee",
        _                 => "Admin"
    };

    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">

            <a class="navbar-brand text-white" asp-controller="Dashboard" asp-action="@dashAction">
                <i class="bi bi-people-fill me-1 text-indigo-300"></i>Employee<span>HR</span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav me-auto gap-1">

                    <!-- Dashboard (all roles) -->
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Dashboard" asp-action="@dashAction">
                            <i class="bi bi-speedometer2 me-1"></i>Dashboard
                        </a>
                    </li>

                    @* ── ADMIN ── *@
                    @if (User.IsInRole("Admin"))
                    {
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Employee"   asp-action="Index"><i class="bi bi-person-badge me-1"></i>Employees</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Department" asp-action="Index"><i class="bi bi-building me-1"></i>Departments</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Attendance" asp-action="Index"><i class="bi bi-clock-history me-1"></i>Attendance</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Leave"      asp-action="Index"><i class="bi bi-calendar-x me-1"></i>Leave</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Payroll"    asp-action="Index"><i class="bi bi-cash-stack me-1"></i>Payroll</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Performance" asp-action="Index"><i class="bi bi-bar-chart-line me-1"></i>Performance</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Appraisal"  asp-action="Index"><i class="bi bi-star-half me-1"></i>Appraisals</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Report"     asp-action="HR"><i class="bi bi-file-earmark-bar-graph me-1"></i>Reports</a></li>
                    }
else if (!hideNav && User.Identity?.IsAuthenticated != true)
{
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand text-white" asp-controller="Home" asp-action="Index">
                <i class="bi bi-people-fill me-1 text-indigo-300"></i>Employee<span>HR</span>
            </a>
            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Account" asp-action="Login">Login</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
}

                    @* ── HR OFFICER ── *@
                    @if (User.IsInRole("HR Officer"))
                    {
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Employee"   asp-action="Index"><i class="bi bi-person-badge me-1"></i>Employees</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Department" asp-action="Index"><i class="bi bi-building me-1"></i>Departments</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Attendance" asp-action="Index"><i class="bi bi-clock-history me-1"></i>Attendance</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Leave"      asp-action="Index"><i class="bi bi-calendar-x me-1"></i>Leave</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Appraisal"  asp-action="Index"><i class="bi bi-star-half me-1"></i>Appraisals</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Report"     asp-action="HR"><i class="bi bi-file-earmark-bar-graph me-1"></i>Reports</a></li>
                    }

                    @* ── PAYROLL OFFICER ── *@
                    @if (User.IsInRole("Payroll Officer"))
                    {
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Payroll" asp-action="Index"><i class="bi bi-cash-stack me-1"></i>Payroll</a></li>
                    }

                    @* ── MANAGER ── *@
                    @if (User.IsInRole("Manager"))
                    {
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Attendance"  asp-action="Index"><i class="bi bi-clock-history me-1"></i>Attendance</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Leave"       asp-action="Index"><i class="bi bi-calendar-x me-1"></i>Leave</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Performance" asp-action="Index"><i class="bi bi-bar-chart-line me-1"></i>Performance</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Appraisal"   asp-action="Index"><i class="bi bi-star-half me-1"></i>Appraisals</a></li>
                    }

                    @* ── EMPLOYEE ── *@
                    @if (User.IsInRole("Employee"))
                    {
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Leave" asp-action="Apply"><i class="bi bi-calendar-plus me-1"></i>Apply Leave</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Leave" asp-action="Index"><i class="bi bi-list-ul me-1"></i>My Leaves</a></li>
                    }

                </ul>

                <!-- Right side: user info + logout -->
                <ul class="navbar-nav ms-auto align-items-center gap-2">
                    <li class="nav-item">
                        <span class="role-badge @roleBadgeClass">
                            <i class="bi bi-person-fill me-1"></i>@User.Identity?.Name
                        </span>
                    </li>
                    <li class="nav-item">
                        <span class="role-badge bg-secondary opacity-75">@role</span>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-sm btn-outline-light rounded-pill px-3" asp-controller="Account" asp-action="Logout">
                            <i class="bi bi-box-arrow-right me-1"></i>Logout
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
}

<div class="container-fluid page-content">
    @RenderBody()
</div>
</div>

<footer class="site-footer text-center">
    <div class="container">
        <small class="muted">&copy; @DateTime.Now.Year Employee HR System — Confidential</small>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
            var result = await ctrl.Index();
            Assert.IsInstanceOf<ViewResult>(result);
            Assert.IsNotNull(ctrl.ViewBag.EmployeeItems);
            Assert.IsNotNull(ctrl.ViewBag.PayrollDetails);
        }


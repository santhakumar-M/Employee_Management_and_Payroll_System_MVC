    [TestFixture]
    public class ControllerTests
    {
        private IServiceProvider BuildServices()
        {
            return new SimpleServiceProvider();
        }

        private class SimpleServiceProvider : IServiceProvider
        {
            public object? GetService(Type serviceType)
            {
                if (serviceType == typeof(IAuthenticationService)) return new FakeAuthenticationService();
                if (serviceType == typeof(IAttendanceService)) return new FakeAttendanceService();
                return null;
            }
        }

        private ControllerContext CreateContext(ClaimsPrincipal? user = null)
        {
            var ctx = new DefaultHttpContext();
            ctx.RequestServices = BuildServices();
            if (user != null) ctx.User = user;
            return new ControllerContext { HttpContext = ctx };
        }

        [Test]
        public async Task Employee_Index_ReturnsViewWithList()
        {
            var ctrl = new EmployeeController(new FakeEmployeeService(), new FakeDepartmentService(), new FakeAccountService())
            {
                ControllerContext = CreateContext()
            };

            var result = await ctrl.Index();
            Assert.IsInstanceOf<ViewResult>(result);
            var view = result as ViewResult;
            Assert.IsInstanceOf<List<Employee>>(view?.Model);
        }

        [Test]
        public async Task Employee_Attendance_NonExisting_ReturnsNotFound()
        {
            var ctrl = new EmployeeController(new FakeEmployeeService(), new FakeDepartmentService(), new FakeAccountService())
            {
                ControllerContext = CreateContext()
            };

            var result = await ctrl.Attendance(99, null);
            Assert.IsInstanceOf<NotFoundResult>(result);
        }

        [Test]
        public void Home_Index_ReturnsView()
        {
            var ctrl = new HomeController();
            var result = ctrl.Index();
            Assert.IsInstanceOf<ViewResult>(result);
        }

        [Test]
        public async Task Account_Login_Post_Invalid_ReturnsView()
        {
            var ctrl = new AccountController(new FakeAccountService())
            {
                ControllerContext = CreateContext()
            };

            var result = await ctrl.Login("", "", "");
            Assert.IsInstanceOf<ViewResult>(result);
        }

        [Test]
        public async Task Account_Login_Post_Valid_Redirects()
        {
            var ctrl = new AccountController(new FakeAccountService())
            {
                ControllerContext = CreateContext()
            };

            var result = await ctrl.Login("valid", "pass", "Employee");
            Assert.IsInstanceOf<RedirectToActionResult>(result);
        }

        [Test]
        public async Task Report_ExportCsv_ReturnsFile()
        {
            var ctrl = new ReportController(new FakeReportService(), new FakeDashboardService())
            {
                ControllerContext = CreateContext()
            };

            var result = await ctrl.ExportCsv(null, null);
            Assert.IsInstanceOf<FileContentResult>(result);
            var file = result as FileContentResult;
            Assert.AreEqual("text/csv", file?.ContentType);
            Assert.IsNotEmpty(file?.FileContents);
        }

        [Test]
        public async Task Leave_Index_ForEmployee_ReturnsView()
        {
            var claims = new[] { new Claim(ClaimTypes.Role, "Employee"), new Claim("EmployeeId", "1") };
            var user = new ClaimsPrincipal(new ClaimsIdentity(claims));

            var ctrl = new LeaveController(new FakeLeaveService(), new FakeEmployeeService())
            {
                ControllerContext = CreateContext(user)
            };

            var result = await ctrl.Index();
            Assert.IsInstanceOf<ViewResult>(result);
        }

        [Test]
        public async Task Payroll_Index_ReturnsViewAndSetsViewBag()
        {
            var ctrl = new PayrollController(new FakePayrollService(), new FakeEmployeeService(), new FakeAttendanceService())
            {
                ControllerContext = CreateContext()

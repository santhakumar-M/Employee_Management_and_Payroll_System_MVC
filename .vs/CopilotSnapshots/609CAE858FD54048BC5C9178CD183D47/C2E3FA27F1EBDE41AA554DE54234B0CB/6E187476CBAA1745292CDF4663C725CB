@model List<EmployeeHrSystem.Models.Attendance>

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>Attendance Records for <span class="text-primary">@ViewBag.SelectedDate.ToString("MMMM dd, yyyy")</span></h2>
        </div>
        <div class="col-md-4 text-end">
            <a asp-controller="Attendance" asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Dates
            </a>
            <a asp-controller="Attendance" asp-action="Mark" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Add Record
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Success!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No attendance records found for this date.
            <a asp-action="Mark" asp-route-date="@ViewBag.SelectedDate.ToString("yyyy-MM-dd")">Mark attendance now</a>
        </div>
    }
    else
    {
        <div class="row mb-3">
            <div class="col-12">
                <div class="card bg-light">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="card-title mb-0">Total Records: <span class="badge bg-primary">@Model.Count</span></h5>
                        </div>
                        <div>
                            <span class="badge bg-success me-2">
                                Present: <span class="fw-bold">@Model.Count(a => a.Status == "PRESENT")</span>
                            </span>
                            <span class="badge bg-danger me-2">
                                Absent: <span class="fw-bold">@Model.Count(a => a.Status == "ABSENT")</span>
                            </span>
                            <span class="badge bg-warning">
                                Leave: <span class="fw-bold">@Model.Count(a => a.Status == "LEAVE")</span>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-bordered">
                <thead class="table-light">
                    <tr>
                        <th style="width: 5%">ID</th>
                        <th style="width: 35%">Employee Name</th>
                        <th style="width: 20%">Status</th>
                        <th style="width: 40%">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var record in Model)
                    {
                        var statusClass = record.Status == "PRESENT" ? "table-success" : 
                                         record.Status == "ABSENT" ? "table-danger" : "table-warning";
                        var badgeClass = record.Status == "PRESENT" ? "bg-success" : 
                                        record.Status == "ABSENT" ? "bg-danger" : "bg-warning";
                        <tr class="@statusClass">
                            <td>@record.AttendanceId</td>
                            <td>
                                <i class="bi bi-person-circle"></i>
                                @record.Employee?.Name
                            </td>
                            <td>
                                <span class="badge @badgeClass">@record.Status</span>
                            </td>
                            <td>
                                <a asp-action="Mark" asp-route-id="@record.AttendanceId" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                                <form asp-action="Delete" asp-route-id="@record.AttendanceId" method="post" style="display: inline;" 
                                      onsubmit="return confirm('Are you sure you want to delete this attendance record?');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@model EmployeeHrSystem.Models.Appraisal

<h2>Record Appraisal</h2>

<form asp-action="Update" asp-controller="Appraisal" method="post">

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="EmployeeId" class="form-label"></label>
        <select asp-for="EmployeeId" class="form-select" asp-items="ViewBag.EmployeeItems">
            <option value="">-- Select Employee --</option>
        </select>
        <span asp-validation-for="EmployeeId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="AppraisalDate" class="form-label"></label>
        <input asp-for="AppraisalDate" type="date" class="form-control" />
        <span asp-validation-for="AppraisalDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="NewSalary" class="form-label"></label>
        <input asp-for="NewSalary" class="form-control" placeholder="e.g. 60000" />
        <span asp-validation-for="NewSalary" class="text-danger"></span>
    </div>

    <button class="btn btn-success" type="submit">Save</button>
    <a asp-action="Index" asp-controller="Appraisal" class="btn btn-secondary">Back</a>

</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
using System.ComponentModel.DataAnnotations;

namespace EmployeeHrSystem.Models
{
    public class Appraisal
    {
        [Key] public int AppraisalId { get; set; }

        [Required(ErrorMessage = "Please select an employee.")]
        [Range(1, int.MaxValue, ErrorMessage = "Please select a valid employee.")]
        [Display(Name = "Employee")]
        public int EmployeeId { get; set; }

        public Employee? Employee { get; set; }

        [Required(ErrorMessage = "Appraisal date is required.")]
        [Display(Name = "Appraisal Date")]
        public DateOnly AppraisalDate { get; set; }

        [Required(ErrorMessage = "New salary is required.")]
        [Range(0.01, 10_000_000, ErrorMessage = "New salary must be greater than 0.")]
        [Display(Name = "New Salary")]
        public decimal NewSalary { get; set; }
    }
}
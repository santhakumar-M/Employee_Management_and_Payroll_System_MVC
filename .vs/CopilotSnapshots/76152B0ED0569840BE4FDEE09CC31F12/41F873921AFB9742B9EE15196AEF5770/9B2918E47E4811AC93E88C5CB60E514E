using System.ComponentModel.DataAnnotations;

namespace EmployeeHrSystem.Models
{
    public class Payroll
    {
        [Key] public int PayrollId { get; set; }

        [Required(ErrorMessage = "Please select an employee.")]
        [Range(1, int.MaxValue, ErrorMessage = "Please select a valid employee.")]
        [Display(Name = "Employee")]
        public int EmployeeId { get; set; }

        public Employee? Employee { get; set; }

        [Required(ErrorMessage = "Month is required.")]
        [RegularExpression(@"^\d{4}-(0[1-9]|1[0-2])$", ErrorMessage = "Month must be in YYYY-MM format (e.g. 2026-03).")]
        [Display(Name = "Month")]
        public string Month { get; set; } = string.Empty;

        [Range(0.01, 10_000_000, ErrorMessage = "Basic salary must be greater than 0.")]
        [Display(Name = "Basic Salary")]
        public decimal BasicSalary { get; set; }

        [Range(0, 10_000_000, ErrorMessage = "Deductions cannot be negative.")]
        [Display(Name = "Deductions")]
        public decimal Deductions { get; set; }

        // Leave / deduction details (not mapped to DB unless you run migrations)
        [System.ComponentModel.DataAnnotations.Schema.NotMapped]
        public int UnpaidDays { get; set; }

        [System.ComponentModel.DataAnnotations.Schema.NotMapped]
        public decimal PerDayDeduction { get; set; }

        [System.ComponentModel.DataAnnotations.Schema.NotMapped]
        public decimal LeaveDeduction { get; set; }

        [Display(Name = "Net Salary")]
        public decimal NetSalary { get; set; }

        [Display(Name = "Payment Status")]
        public string PaymentStatus { get; set; } = "PENDING";
    }
}

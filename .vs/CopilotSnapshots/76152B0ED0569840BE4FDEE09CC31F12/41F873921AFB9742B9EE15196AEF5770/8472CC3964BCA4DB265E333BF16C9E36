@model Employee

<h2>Create Employee</h2>

<form asp-action="Create" method="post" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="col-12 text-danger"></div>
    <div class="col-md-6">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" placeholder="e.g. John Smith" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="Designation" class="form-label"></label>
        <input asp-for="Designation" class="form-control" placeholder="e.g. Software Engineer" />
        <span asp-validation-for="Designation" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="DepartmentId" class="form-label"></label>
        <select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.Departments">
            <option value="">-- Select Department --</option>
        </select>
        <span asp-validation-for="DepartmentId" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="BasicSalary" class="form-label"></label>
        <input asp-for="BasicSalary" class="form-control" placeholder="e.g. 50000" />
        <span asp-validation-for="BasicSalary" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label asp-for="ContactInfo" class="form-label"></label>
        <input asp-for="ContactInfo" class="form-control" placeholder="e.g. +1-555-0100 or email@example.com" />
        <span asp-validation-for="ContactInfo" class="text-danger"></span>
    </div>

    <hr class="my-3" />

    <div class="col-12">
        <h5>Account (optional)</h5>
        <small class="text-muted">Leave username and password blank to skip account creation.</small>
    </div>
    <div class="col-md-4">
        <label class="form-label">Role</label>
        <select name="role" class="form-select">
            <option value="Employee">Employee</option>
            <option value="Manager">Manager</option>
            <option value="HR Officer">HR Officer</option>
            <option value="Payroll Officer">Payroll Officer</option>
            <option value="Admin">Admin</option>
        </select>
    </div>
    <div class="col-md-4">
        <label class="form-label">Username</label>
        <input name="username" class="form-control" placeholder="e.g. jsmith" />
    </div>
    <div class="col-md-4">
        <label class="form-label">Password</label>
        <input name="password" type="password" class="form-control" placeholder="Min. 6 characters" />
    </div>

    <div class="col-12">
        <button class="btn btn-success" type="submit">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
@model EmployeeHrSystem.Models.LeaveRequest

<h2>Apply Leave</h2>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">@ViewBag.Error</div>
}

<form asp-action="Apply" asp-controller="Leave" method="post">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label asp-for="EmployeeId" class="form-label"></label>
        <select asp-for="EmployeeId"
                class="form-select"
                asp-items="@((IEnumerable<SelectListItem>)ViewBag.EmployeeItems)">
            <option value="">-- Select Employee --</option>
        </select>
        <span asp-validation-for="EmployeeId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="StartDate" class="form-label"></label>
        <input asp-for="StartDate" type="date" class="form-control" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="EndDate" class="form-label"></label>
        <input asp-for="EndDate" type="date" class="form-control" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="LeaveType" class="form-label"></label>
        <select asp-for="LeaveType" class="form-select">
            <option>CASUAL</option>
            <option>SICK</option>
            <option>ANNUAL</option>
        </select>
        <span asp-validation-for="LeaveType" class="text-danger"></span>
    </div>

    <input type="hidden" asp-for="Status" value="APPLIED" />

    <button type="submit" class="btn btn-success">Apply</button>
    <a asp-action="Index" asp-controller="Leave" class="btn btn-secondary">Back</a>
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}

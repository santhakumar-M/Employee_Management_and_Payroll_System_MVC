@using EmployeeHrSystem.Models
@model List<EmployeeAttendanceItem>

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2>Attendance Records for <span class="text-primary">@ViewBag.SelectedDate.ToString("MMMM dd, yyyy")</span></h2>
        </div>
        <div class="col-md-4 text-end">
            <a asp-controller="Attendance" asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Dates
            </a>
            <a asp-controller="Attendance" asp-action="MarkForDay" asp-route-date="@ViewBag.SelectedDate.ToString("yyyy-MM-dd")" class="btn btn-success">
                <i class="bi bi-pencil"></i> Edit
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>Success!</strong> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error!</strong> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model == null || Model.Count == 0)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> No employee records found for this date.
            <a asp-action="MarkForDay" asp-route-date="@ViewBag.SelectedDate.ToString("yyyy-MM-dd")">Mark attendance now</a>
        </div>
    }
    else
    {
        <div class="row mb-3">
            <div class="col-12">
                <div class="card bg-light">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <h5 class="card-title mb-0">Total Employees: <span class="badge bg-primary">@Model.Count</span></h5>
                        </div>
                        <div>
                            <span class="badge bg-success me-2">
                                Present: <span class="fw-bold">@Model.Count(a => a.Status == "PRESENT")</span>
                            </span>
                            <span class="badge bg-danger me-2">
                                Absent: <span class="fw-bold">@Model.Count(a => a.Status == "ABSENT")</span>
                            </span>
                            <span class="badge bg-info">
                                Leave: <span class="fw-bold">@Model.Count(a => a.Status == "LEAVE")</span>
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover table-bordered">
                <thead class="table-light">
                    <tr>
                        <th style="width: 40%">Employee Name</th>
                        <th style="width: 30%">Designation</th>
                        <th style="width: 20%">Status</th>
                        <th style="width: 10%"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var employee in Model)
                    {
                        var statusClass = employee.Status == "PRESENT" ? "table-success" 
                            : employee.Status == "LEAVE" ? "table-info" : "table-danger";
                        var badgeClass = employee.Status == "PRESENT" ? "bg-success" 
                            : employee.Status == "LEAVE" ? "bg-info" : "bg-danger";
                        <tr class="@statusClass">
                            <td>
                                <i class="bi bi-person-circle"></i>
                                <strong>@employee.EmployeeName</strong>
                            </td>
                            <td>
                                @employee.Designation
                            </td>
                            <td>
                                <span class="badge @badgeClass">@employee.Status</span>
                            </td>
                            <td class="text-center">
                                @if (employee.Status == "PRESENT")
                                    {
                                        <span class="text-success"><i class="bi bi-check-circle-fill"></i></span>
                                    }
                                    else if (employee.Status == "LEAVE")
                                    {
                                        <span class="text-info"><i class="bi bi-calendar-check-fill"></i></span>
                                    }
                                    else
                                    {
                                        <span class="text-danger"><i class="bi bi-x-circle-fill"></i></span>
                                    }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

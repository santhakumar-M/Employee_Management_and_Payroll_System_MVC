
    @model List<EmployeeHrSystem.Models.Payroll>

    <h2>Payroll</h2>

    <form asp-action="Process" asp-controller="Payroll" method="post">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="row g-3 mb-3">
        <div class="col-md-4">
            <label class="form-label">Employee</label>
            <select name="employeeId"
                    class="form-select"
                    asp-items="ViewBag.EmployeeItems" required>
                <option value="">-- select --</option>
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label">Month (YYYY-MM)</label>
            <input name="month" class="form-control" placeholder="2026-03" required />
        </div>

        <div class="col-md-3 align-self-end">
            <div class="d-flex gap-2">
                <div class="form-check align-self-center me-2">
                    <input class="form-check-input" type="checkbox" value="true" id="applyLeaveDeduction" name="applyLeaveDeduction" />
                    <label class="form-check-label muted" for="applyLeaveDeduction">Apply leave deduction</label>
                </div>
                <button type="submit" class="btn btn-primary">Process</button>
            </div>
        </div>
    </div>
</form>
<table class="table table-bordered mt-3">
    <thead>
        <tr>
            <th>Employee</th>
            <th>Month</th>
            <th>Basic</th>
            <th>Deductions</th>
            <th>Unpaid days</th>
            <th>Per day</th>
            <th>Leave deduction</th>
            <th>Net</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in Model)
        {
            var details = ViewBag.PayrollDetails as System.Collections.Generic.Dictionary<int, EmployeeHrSystem.Models.PayrollDetailInfo>;
            <tr>
                <td>@p.Employee?.Name</td>
                <td>@p.Month</td>
                <td>@p.BasicSalary</td>
                <td>@p.Deductions</td>
                <td>@(details != null && details.ContainsKey(p.PayrollId) ? details[p.PayrollId].UnpaidDays.ToString() : "-")</td>
                <td>@(details != null && details.ContainsKey(p.PayrollId) ? details[p.PayrollId].PerDayDeduction.ToString("F2") : "-")</td>
                <td>@(details != null && details.ContainsKey(p.PayrollId) ? details[p.PayrollId].LeaveDeduction.ToString("F2") : "-")</td>
                <td>@p.NetSalary</td>
                <td>@p.PaymentStatus</td>
            </tr>
        }
    </tbody>
</table>
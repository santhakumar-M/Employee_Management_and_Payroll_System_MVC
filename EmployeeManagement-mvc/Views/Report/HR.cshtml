@model EmployeeHrSystem.Models.HRReportViewModel

@{
    ViewData["Title"] = "HR Monthly Report";
}

<div class="card card-custom mb-4 p-3">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h3 class="mb-0">@Model.CompanyName</h3>
            <div class="muted">@Model.ReportingPeriod</div>
        </div>
        <div class="text-end muted small">Generated: @Model.GeneratedOn.ToString("yyyy-MM-dd")</div>
    </div>

    <hr />

    <div class="row">
        <div class="col-md-4">
            <div class="mb-2 muted">Total employees</div>
            <div class="h4">@Model.TotalEmployees</div>
        </div>
        <div class="col-md-4">
            <div class="mb-2 muted">Active employees</div>
            <div class="h4">@Model.ActiveEmployees</div>
        </div>
        <div class="col-md-4">
            <div class="mb-2 muted">New hires</div>
            <div class="h4">@Model.NewHires</div>
        </div>
    </div>

    <hr />

    <div class="row">
        <div class="col-md-6">
            <div class="mb-2 muted">Total Gross Salary</div>
            <div class="h5">@Model.TotalGrossSalary.ToString("C")</div>
        </div>
        <div class="col-md-6">
            <div class="mb-2 muted">Total Deductions</div>
            <div class="h5">@Model.TotalDeductions.ToString("C")</div>
        </div>
    </div>

    <div class="text-muted small mt-3">Generated by Employee Payroll Management System</div>
</div>

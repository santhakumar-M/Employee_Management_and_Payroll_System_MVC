@model EmployeeHrSystem.Models.EmployeeAttendanceSummaryViewModel

@{
    ViewData["Title"] = "Attendance";
}

<div class="card card-custom p-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h5 class="mb-0">Attendance for @Model.Employee?.Name</h5>
            <small class="muted">Month: @Model.Month</small>
        </div>
        <div>
            <a asp-action="Index" asp-controller="Employee" class="btn btn-sm btn-outline-secondary">Back</a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="border p-3">
                <div class="muted">Present days</div>
                <div class="h4">@Model.PresentDays</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="border p-3">
                <div class="muted">Absent days</div>
                <div class="h4">@Model.AbsentDays</div>
            </div>
        </div>
    </div>

    <hr />

    <h6>Detailed records</h6>
    <table class="table table-sm">
        <thead>
            <tr><th>Date</th><th>Status</th></tr>
        </thead>
        <tbody>
            @foreach (var r in Model.Records)
            {
                <tr>
                    <td>@r.Date.ToString("yyyy-MM-dd")</td>
                    <td>@r.Status</td>
                </tr>
            }
        </tbody>
    </table>
</div>
